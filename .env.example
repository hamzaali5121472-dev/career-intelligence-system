# Career Intelligence System — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it's in .gitignore

# ============================================================
# REDDIT API (reddit.com/prefs/apps → Create App → script)
# ============================================================
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=b2have_career_intel/1.0 by /u/your_reddit_username
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ============================================================
# ANTHROPIC CLAUDE API (console.anthropic.com → API Keys)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ============================================================
# GOOGLE CLOUD (console.cloud.google.com → Service Account)
# Path to your downloaded service account JSON file
# ============================================================
GOOGLE_SERVICE_ACCOUNT_FILE=config/google_service_account.json
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# ============================================================
# EMAIL ALERTS (Gmail App Password — not your main password)
# Enable 2FA → Google Account → Security → App Passwords
# ============================================================
ALERT_EMAIL_FROM=your_gmail@gmail.com
ALERT_EMAIL_TO=hamzaali5121472@gmail.com
ALERT_EMAIL_APP_PASSWORD=your_16_char_app_password

# ============================================================
# JOB BANK CANADA API (Optional — free registration)
# jobbank.gc.ca/developers
# ============================================================
JOB_BANK_API_KEY=your_job_bank_key_here

# ============================================================
# YOUTUBE DATA API (Phase 2 — console.cloud.google.com)
# Enable YouTube Data API v3 in your Google Cloud project
# ============================================================
YOUTUBE_API_KEY=your_youtube_api_key_here

# ============================================================
# SYSTEM SETTINGS
# ============================================================
# Minimum relevance score to include in Drive doc (0-10)
MIN_RELEVANCE_SCORE=6

# Environment: development or production
ENVIRONMENT=development
